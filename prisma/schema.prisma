generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model ChatbotMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
}
